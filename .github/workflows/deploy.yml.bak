name: Deploy Hugo site to GitHub Pages

on:
  push:
    branches:
      - main  # Or change to 'master' if your default branch is 'master'

jobs:
  deploy:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout source code
        uses: actions/checkout@v4
 
      - name: Setup Hugo (Extended version)
        uses: peaceiris/actions-hugo@v2
        with:
          hugo-version: 'latest'
          extended: true

      - name: Build with Hugo
        run: hugo --minify

      - name: Deploy to GitHub Pages
        uses: peaceiris/actions-gh-pages@v3
        with:
          github_token: ${{ secrets.GITHUB_TOKEN }}  # Uses default secure GitHub Actions token
          publish_dir: ./public                      # Hugo’s output folder
