baseURL = "https://gplusunblocked.github.io/"
languageCode = "en"
defaultContentLanguage = "en"
theme = "revws"
buildFuture = true
contentDir = "content"
publishDir = "public"
relativeURLs = true
canonifyURLs = false

[pagination]
  pagerSize = 5

[params]
  # ... your params unchanged ...

# Allow raw HTML
[markup]
  [markup.goldmark]
    [markup.goldmark.renderer]
      unsafe = true
